# ============================================
# Authentication Configuration (REQUIRED)
# ============================================
# Choose ONE authentication method:

# Option 1: API Key (recommended for production)
# Get your API key from: https://agent.unbrowse.ai/dashboard
UNBROWSE_API_KEY=re_xxxxxxxxxxxxx

# Option 2: Session Token (alternative to API key)
# Get from browser cookies after logging in
# UNBROWSE_SESSION_TOKEN=cm4xxxxxxxxxxxxx

# ============================================
# Credential Decryption (OPTIONAL)
# ============================================
# Only required if your abilities need to decrypt stored credentials
# This is the password you set when storing credentials in the dashboard
UNBROWSE_PASSWORD=your-encryption-password

# Alternative environment variable name (same as UNBROWSE_PASSWORD)
# UNBROWSE_CREDENTIAL_KEY=your-encryption-password

# ============================================
# Optional Configuration
# ============================================

# Proxy Configuration (optional)
# Format: http://username:password@host:port
PROXY_URL=

# Enable Index Tool (optional, defaults to false)
# Set to true to enable the ingest_api_endpoint tool for indexing new APIs
ENABLE_INDEX_TOOL=false

# ============================================
# X402 Payment Configuration (OPTIONAL)
# ============================================

# --- For HOSTING paid MCP servers (you charge others) ---
# Enable payment protection for MCP server endpoints
# Requires setting up a Solana wallet to receive payments

# Enable x402 payment protection (defaults to false)
ENABLE_X402_PAYMENTS=false

# Your Solana wallet address to receive payments
X402_WALLET_ADDRESS=your-solana-wallet-address

# Network to use: "devnet" or "mainnet" (defaults to devnet)
X402_NETWORK=devnet

# Pricing tier: BASIC, STANDARD, PREMIUM, ENTERPRISE (defaults to BASIC)
# BASIC: $0.0001 per request
# STANDARD: $0.001 per request
# PREMIUM: $0.01 per request
# ENTERPRISE: $0.10 per request
X402_PRICING_TIER=BASIC

# HTTP server configuration
HTTP_PORT=3000
HTTP_HOST=localhost

# --- For CALLING paid APIs (you pay others) ---
# Your wallet's private key for making payments to x402-protected APIs
# This enables the call_x402_api tool in the MCP server
# IMPORTANT: Keep this secret! Never commit to git.
# Format: 0x... (hex string starting with 0x)
X402_PRIVATE_KEY=0xyour-private-key-here

# Optional: Default base URL for x402 API calls
# If set, you can use relative URLs in the call_x402_api tool
X402_DEFAULT_BASE_URL=

# ============================================
# Tool Credential Overrides (OPTIONAL)
# ============================================
# For abilities that require API keys/tokens from environment variables
# instead of encrypted storage

# Option 1: JSON mapping of dynamic header keys -> values (recommended)
# UNBROWSE_TOOL_HEADERS='{"reverse-engineer::x-api-key":"your-api-key","reverse-engineer::authorization":"Bearer your-token"}'

# Option 2: Sanitized environment variables (DOMAIN__HEADER, uppercase, non-alphanumeric -> _)
# REVERSE_ENGINEER__X_API_KEY=your-api-key
# REVERSE_ENGINEER__AUTHORIZATION=Bearer your-token
